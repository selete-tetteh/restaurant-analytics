# Data files - raw data is never committed to Git for two reasons:
# 1. File sizes are often too large for GitHub
# 2. Source data should always be pulled from the original source, not copied between machines
data/raw/*
data/processed/*

# Keep the folder structure visible despite ignoring contents
!data/raw/.gitkeep
!data/processed/.gitkeep

# R session artefacts - these are machine-specific and have no place in version control
.Rhistory
.RData
.Rproj.user/

# Python artefacts
__pycache__/
*.py[cod]
*.egg-info/
.env

# Jupyter checkpoints - auto-generated by Jupyter, not actual code
.ipynb_checkpoints/

# macOS system file - created automatically by Finder, meaningless to anyone else
.DS_Store

# Conda environment folder if anyone installs locally rather than using environment.yml
env/
venv/
